# Embedding model configuration
DOCCHAT_EMBEDDING_MODEL=rasyosef/RoBERTa-Amharic-Embed-Medium
DOCCHAT_MODELS_DIR=./data/models
DOCCHAT_CACHE_DIR=./model_cache

# Text chunking
DOCCHAT_CHUNK_SIZE=800
DOCCHAT_CHUNK_OVERLAP=150

# ChromaDB
DOCCHAT_CHROMA_PERSIST_DIR=./data/chroma_db
DOCCHAT_COLLECTION_NAME=documents

# Ollama LLM
DOCCHAT_OLLAMA_URL=http://localhost:11434/api/generate
DOCCHAT_OLLAMA_MODEL=qwen3.5:0.8b

# Retrieval
DOCCHAT_N_RETRIEVAL_CHUNKS=5
